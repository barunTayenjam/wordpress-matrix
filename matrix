#!/bin/bash
# Simplified WordPress Development Platform - All-in-One Management Script

set -euo pipefail

# Configuration
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$SCRIPT_DIR"
DOMAIN_SUFFIX="127.0.0.1.nip.io"
COMPOSE_FILE="$PROJECT_ROOT/docker-compose.yml"
DOCKER_COMPOSE="docker-compose"  # Default fallback
DEFAULT_PHP_VERSION="8.3"  # Default PHP version for new sites

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

JSON_OUTPUT=false

output_json() {
    echo "$1"
}

error_json() {
    local code="$1"
    local message="$2"
    printf '{"success":false,"error":{"code":"%s","message":"%s"}}\n' "$code" "$message"
    exit 1
}

check_docker_json() {
    if [[ "$JSON_OUTPUT" == true ]]; then
        if ! docker info >/dev/null 2>&1; then
            error_json "DOCKER_ERROR" "Docker daemon is not running"
        fi
    fi
}

# Sanitize site name for SQL usage
sanitize_sql_identifier() {
    local input="$1"
    # Remove any characters that could be SQL injection
    echo "$input" | tr -cd 'a-zA-Z0-9_-'
}

# Helper functions
log_info() { echo -e "${BLUE}ℹ️  $1${NC}"; }
log_success() { echo -e "${GREEN}✅ $1${NC}"; }
log_warning() { echo -e "${YELLOW}⚠️  $1${NC}"; }
log_error() { echo -e "${RED}❌ $1${NC}"; }

json_log_override() {
    if [[ "$JSON_OUTPUT" == true ]]; then
        log_info() { :; }
        log_success() { :; }
        log_warning() { :; }
        log_error() { :; }
    fi
}

# Load environment
if [[ -f "$PROJECT_ROOT/.env" ]]; then
    set -a
    source "$PROJECT_ROOT/.env"
    set +a
fi

# Use podman-compose instead of docker-compose
if command -v podman-compose >/dev/null 2>&1; then
    DOCKER_COMPOSE="podman-compose"
elif command -v docker-compose >/dev/null 2>&1; then
    DOCKER_COMPOSE="docker-compose"
else
    log_error "Neither docker-compose nor podman-compose found"
    exit 1
fi

