<div class="tab-content">
  <!-- Dashboard Tab -->
  <div class="tab-pane fade show active" id="dashboard">
    <div class="row g-3 mb-4">
      <div class="col-md-3">
        <div class="card stat-card text-center h-100">
          <div class="card-body d-flex flex-column justify-content-center align-items-center">
            <h5 class="card-title">{{sites.length}}</h5>
            <p class="card-text text-muted mb-0">Total Sites</p>
            <i class="bi bi-hdd-stack" style="font-size: 1.75rem; color: var(--primary-color);"></i>
          </div>
        </div>
      </div>
      <div class="col-md-3">
        <div class="card stat-card text-center h-100">
          <div class="card-body d-flex flex-column justify-content-center align-items-center">
            <h5 class="card-title" id="running-sites-count">{{#each sites}}{{#if (eq status "Running")}}1{{/if}}{{/each}}</h5>
            <p class="card-text text-muted mb-0">Running Sites</p>
            <i class="bi bi-play-circle" style="font-size: 1.75rem; color: var(--success-color);"></i>
          </div>
        </div>
      </div>
      <div class="col-md-3">
        <div class="card stat-card text-center h-100">
          <div class="card-body d-flex flex-column justify-content-center align-items-center">
            <h5 class="card-title">{{services.length}}</h5>
            <p class="card-text text-muted mb-0">Services</p>
            <i class="bi bi-server" style="font-size: 1.75rem; color: #0ea5e9;"></i>
          </div>
        </div>
      </div>
      <div class="col-md-3">
        <div class="card stat-card text-center h-100">
          <div class="card-body d-flex flex-column justify-content-center align-items-center">
            <h5 class="card-title" id="running-services-count">{{#each services}}{{#if (eq status "Running")}}1{{/if}}{{/each}}</h5>
            <p class="card-text text-muted mb-0">Running Services</p>
            <i class="bi bi-cpu" style="font-size: 1.75rem; color: var(--warning-color);"></i>
          </div>
        </div>
      </div>
    </div>

    <!-- Quick Actions -->
    <div class="row mt-4">
      <div class="col-12">
        <h3 class="mb-3">Quick Actions</h3>
        <div class="d-flex gap-2 flex-wrap">
          <button class="btn btn-success" onclick="quickAction('start')">
            <i class="bi bi-play-fill"></i> Start All
          </button>
          <button class="btn btn-outline-secondary" onclick="quickAction('stop')">
            <i class="bi bi-stop-fill"></i> Stop All
          </button>
          <button class="btn btn-outline-secondary" onclick="quickAction('restart')">
            <i class="bi bi-arrow-clockwise"></i> Restart All
          </button>
          <button class="btn btn-outline-primary" onclick="quickAction('check')">
            <i class="bi bi-clipboard-check"></i> Code Quality
          </button>
          <button class="btn btn-outline-warning" onclick="quickAction('clean')">
            <i class="bi bi-trash"></i> Clean Resources
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- Sites Tab -->
  <div class="tab-pane fade" id="sites">
    <div class="d-flex justify-content-between align-items-center mb-3">
      <h3>Sites Management</h3>
      <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#createSiteModal">
        <i class="bi bi-plus-circle"></i> Create Site
      </button>
    </div>

    <div class="row g-3">
      {{#each sites}}
      <div class="col-md-6 col-lg-4 mb-3">
        <div class="card site-card h-100">
          <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="card-title mb-0">{{name}}</h5>
            <span class="{{#if (eq status "Running")}}badge-r{{else}}badge-s{{/if}}">
              {{status}}
            </span>
          </div>
          <div class="card-body">
            <p class="card-text mb-2">
              <i class="bi bi-link me-2"></i><span class="text-muted">{{localUrl}}</span>
            </p>
            <p class="card-text mb-2 site-health" id="health-{{name}}" style="display: none;">
              <i class="bi bi-heart-pulse me-2"></i><span class="health-status"></span>
            </p>
            {{#if localUrl}}
            <a href="{{localUrl}}" target="_blank" class="btn btn-sm btn-outline-primary mt-2">
              <i class="bi bi-box-arrow-up-right"></i> Open Site
            </a>
            <button class="btn btn-sm btn-outline-secondary mt-2" onclick="checkSiteHealth('{{name}}')">
              <i class="bi bi-heart-pulse"></i> Health
            </button>
            {{/if}}
          </div>
          <div class="card-footer d-flex justify-content-between flex-wrap gap-2">
            <button class="btn btn-sm btn-success" onclick="siteAction('start', '{{name}}')">
              <i class="bi bi-play"></i> Start
            </button>
            <button class="btn btn-sm btn-warning" onclick="siteAction('stop', '{{name}}')">
              <i class="bi bi-stop"></i> Stop
            </button>
            <button class="btn btn-sm btn-info" onclick="siteAction('info', '{{name}}')">
              <i class="bi bi-info"></i> Info
            </button>
            <button class="btn btn-sm btn-outline-info" onclick="runChecksForSite('{{name}}')">
              <i class="bi bi-clipboard-check"></i> Check
            </button>
            <button class="btn btn-sm btn-danger" onclick="siteAction('remove', '{{name}}')">
              <i class="bi bi-trash"></i> Delete
            </button>
          </div>
        </div>
      </div>
      {{/each}}
    </div>
  </div>

  <!-- Services Tab -->
  <div class="tab-pane fade" id="services">
    <h3>Services Status</h3>
    <div class="table-responsive">
      <table class="table table-striped">
        <thead>
          <tr>
            <th>Service</th>
            <th>Status</th>
            <th>Local URL</th>
            <th>Description</th>
          </tr>
        </thead>
        <tbody>
          {{#each services}}
          <tr>
            <td><strong>{{name}}</strong></td>
            <td>
              <span class="badge {{#if (eq status "Running")}}bg-success{{else}}bg-secondary{{/if}}">
                {{status}}
              </span>
            </td>
            <td>
              {{#if (ne localUrl "Internal")}}
              <a href="{{localUrl}}" target="_blank">{{localUrl}}</a>
              {{else}}
              {{localUrl}}
              {{/if}}
            </td>
            <td>
              <span class="badge bg-secondary">Services</span>
            </td>
          </tr>
          {{/each}}
        </tbody>
      </table>
    </div>
  </div>

  <!-- Frontend Tab -->
  <div class="tab-pane fade" id="frontend">
    <h3>Frontend Management</h3>
    <div class="card">
      <div class="card-header">
        <h5 class="card-title mb-0">Web Interface</h5>
      </div>
      <div class="card-body">
        <div class="row">
          <div class="col-md-6">
            <h6>Status</h6>
            <div id="frontend-status">Checking...</div>
            <div class="mt-2">
              <a href="http://localhost:8000" target="_blank" class="btn btn-primary">
                <i class="bi bi-box-arrow-up-right"></i> Open Frontend
              </a>
            </div>
          </div>
          <div class="col-md-6">
            <h6>Controls</h6>
            <div class="d-grid gap-2">
              <button class="btn btn-success" onclick="frontendAction('start')">
                <i class="bi bi-play-fill"></i> Start
              </button>
              <button class="btn btn-danger" onclick="frontendAction('stop')">
                <i class="bi bi-stop-fill"></i> Stop
              </button>
              <button class="btn btn-secondary" onclick="frontendAction('restart')">
                <i class="bi bi-arrow-clockwise"></i> Restart
              </button>
              <button class="btn btn-info" onclick="frontendAction('status')">
                <i class="bi bi-info-circle"></i> Status
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Terminal Tab -->
  <div class="tab-pane fade" id="terminal">
    <h3>Terminal Interface</h3>
    <div class="mb-3">
      <div class="input-group">
        <span class="input-group-text">{{matrixCommand}}</span>
        <input type="text" id="terminal-input" class="form-control" placeholder="Enter matrix command..." 
               onkeypress="if(event.key === 'Enter') { executeCommand(); }">
        <button class="btn btn-primary" onclick="executeCommand()">Execute</button>
      </div>
    </div>
    <div id="terminal-output" class="terminal-output">
      <div style="color: var(--accent-color);">WordPress Matrix Terminal v1.0</div>
      <div style="color: var(--text-secondary);">Type 'help' for available commands.</div>
      <div style="color: var(--text-secondary); margin-top: 0.5rem;">--- --- --- --- --- ---</div>
    </div>
  </div>
</div>

<!-- Create Site Modal -->
<div class="modal fade" id="createSiteModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Create New Site</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <div class="mb-3">
          <label for="siteName" class="form-label">Site Name</label>
          <input type="text" class="form-control" id="siteName" placeholder="Enter site name...">
          <div class="form-text">Use alphanumeric characters, hyphens, and underscores only.</div>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-primary" onclick="createSite()">Create Site</button>
      </div>
    </div>
  </div>
</div>

<!-- Code Quality Results Modal -->
<div class="modal fade" id="checkResultsModal" tabindex="-1">
  <div class="modal-dialog modal-lg">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Code Quality Check Results</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body" id="check-results-body">
        <div id="check-progress" class="text-center">
          <div class="spinner-border" role="status"></div>
          <p>Running checks...</p>
        </div>
        <div id="check-output" class="d-none">
          <pre class="bg-dark text-light p-3"></pre>
        </div>
      </div>
    </div>
  </div>
</div>